{
  // ==========================================================================
  // Claude DataScience DevContainer — Debug Configurations
  // ==========================================================================
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: 현재 파일",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "/home/vscode/miniconda3/envs/ds/bin/python"
    },
    {
      "name": "Python: 모듈",
      "type": "debugpy",
      "request": "launch",
      "module": "${command:pickModule}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "/home/vscode/miniconda3/envs/ds/bin/python"
    },
    {
      "name": "Node.js: 현재 파일",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
