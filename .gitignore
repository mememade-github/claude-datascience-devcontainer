# =============================================================================
# Claude DataScience DevContainer - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# 환경 설정 (민감 정보)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
!.devcontainer/.env

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
.venv/
venv/

# -----------------------------------------------------------------------------
# Jupyter / Data Science
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
.jupyter/
*.csv.gz
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.onnx
data/raw/
data/processed/
models/
outputs/
mlruns/
wandb/

# -----------------------------------------------------------------------------
# Conda
# -----------------------------------------------------------------------------
*.conda
*.tar.bz2

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/settings.local.json
*.code-workspace

# -----------------------------------------------------------------------------
# Claude Code (런타임 마커 — 커밋 불필요)
# -----------------------------------------------------------------------------
.claude/.tool-call-counter
.claude/.last-verification
.claude/.last-evolution
.claude/.pending-review
.claude/.review-done
.claude/subagent.log
.claude/.update-check-cache
.claude/settings.local.json
.mcp.json

# -----------------------------------------------------------------------------
# 기타
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
*.bak
*~
